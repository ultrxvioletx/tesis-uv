	file = {PDF:/home/ultrxvioletx/Zotero/storage/78T5A4T2/Forn-Díaz et al. - 2019 - Ultrastrong coupling regimes of light-matter interaction.pdf:application/pdf},
}

@article{garziano_multiphoton_2015,
	title = {Multiphoton {Quantum} {Rabi} {Oscillations} in {Ultrastrong} {Cavity} {QED}},
