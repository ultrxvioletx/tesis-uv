@article{pillet_controllable_2009,
	title = {Controllable interactions between {Rydberg} atoms and ultracold plasmas},
	volume = {194},
	issn = {1742-6596},
	url = {https://iopscience.iop.org/article/10.1088/1742-6596/194/1/012066},
	doi = {10.1088/1742-6596/194/1/012066},
	abstract = {We discuss the control of dipole-dipole interactions in a frozen assembly of Rydberg atoms. We report the evidence of dipole blockade of the Rydberg excitation for two configurations: dipole blockade induced by electric field and dipole blockade in Förster resonance. We demonstrate that two individual atoms separated by {\textasciitilde} 4 µm can act as a collective dipole if their interaction is strong enough to be in the dipole blockade regime. This observation is crucial for the quantum entanglement of two or more atoms using dipole-dipole interaction. The dipole-dipole interactions between Rydberg atoms are also responsible for Penning ionization leading to the formation of an ultracold plasma. We have demonstrated that Penning ionization of np Rydberg cesium atoms can be prevented by considering repulsive dipole-dipole interactions.},
	language = {en},
	number = {1},
	urldate = {2026-03-20},
	journal = {Journal of Physics: Conference Series},
	author = {Pillet, P and Vogt, T and Viteau, M and Chotia, A and Zhao, J and Comparat, D and Gallagher, T F and Tate, D and Gaëtan, A and Miroshnychenko, Y and Wilk, T and Browaeys, A and Grangier, P},
	month = nov,
	year = {2009},
	pages = {012066},
	file = {PDF:files/117/Pillet et al. - 2009 - Controllable interactions between Rydberg atoms and ultracold plasmas.pdf:application/pdf},
}

