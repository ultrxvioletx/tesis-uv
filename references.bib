	file = {PDF:/home/ultrxvioletx/Zotero/storage/3VMXP5QM/Nguyen Thi Thu et al. - 2023 - Double electromagnetically induced transparency in a four-level lambda atomic system with doppler br.pdf:application/pdf},
}

@article{bharti_study_2015,
	title = {Study of a four-level system in vee + ladder configuration},
	volume = {356},
	issn = {00304018},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0030401815300341},
	doi = {10.1016/j.optcom.2015.08.042},
	abstract = {We present the results of a theoretical study of a four-level atomic system in vee þ ladder conﬁguration using a density matrix analysis. The absorption and dispersion proﬁles are derived for a weak probe ﬁeld and for varying strengths of the two strong control ﬁelds. For speciﬁcity, we choose energy levels of 87Rb, and present results for both stationary atoms and moving atoms in room temperature vapor. An electromagnetically induced absorption (EIA) peak with negative dispersion is observed at zero probe detuning when the control ﬁelds have equal strengths, which switches to electromagnetically induced transparency (EIT) with positive dispersion (due to splitting of the EIA peak) when the control ﬁelds are unequal. There is signiﬁcant linewidth narrowing in thermal vapor.},
