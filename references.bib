	note = {arXiv:1609.03090 [quant-ph]},
	keywords = {Quantum Physics},
	pages = {053842},
	annote = {Comment: 17 pages, 8 figures},
	file = {PDF:/home/ultrxvioletx/Zotero/storage/P297D62W/Liao et al. - 2016 - Dynamical theory of single photon transport in a one-dimensional waveguide coupled to identical and.pdf:application/pdf},
}

