@article{tian_quantum_2024,
	title = {Quantum state preparation in {Jaynes}-{Cummings} lattices},
	volume = {2912},
	issn = {1742-6588, 1742-6596},
	url = {https://iopscience.iop.org/article/10.1088/1742-6596/2912/1/012041},
	doi = {10.1088/1742-6596/2912/1/012041},
	abstract = {One of the key questions in quantum information is the preparation of desired multipartite quantum states with high ﬁdelity. Adiabatic evolution has been widely explored to achieve state preparation in quantum many-body systems. However, in noisy quantum systems, the adiabatic approach faces a dilemma: either extending the evolution timescales to reduce diabatic transitions or shortening the timescales to mitigate decoherence eﬀects. Various quantum control approaches have been studied to resolve this dilemma. In a few recent works, we utilized Jaynes-Cummings (JC) lattices as a platform to investigate the potential of several quantum control techniques in preparing quantum many-body states, including the optimized adiabatic evolution approach, the quantum optimal control technique, and quantum shortcuts to adiabaticity. Here we ﬁrst give an overview of our previous results on utilizing quantum optimal control in JC lattices with unit ﬁlling and utilizing local counterdiabatic driving in JC lattices with a single excitation. Then we present our results on the energy costs and energy ﬂuctuations in these approaches. Our studies give insights into the implementation of diﬀerent approaches in practical quantum devices and the connection between the energy costs and the quantum speed limit in preparing desired quantum many-body states for quantum simulation and quantum computation.},
	language = {en},
	number = {1},
	urldate = {2026-04-02},
	journal = {Journal of Physics: Conference Series},
	author = {Tian, Lin and Govindarajan, Anuvetha and Parajuli, Prabin and Cai, Kang},
	month = dec,
	year = {2024},
	pages = {012041},
	file = {PDF:/home/ultrxvioletx/Zotero/storage/FU4KJMZR/Tian et al. - 2024 - Quantum state preparation in Jaynes-Cummings lattices.pdf:application/pdf},
}

