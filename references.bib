@article{nguyen_thi_thu_double_2023,
	title = {Double electromagnetically induced transparency in a four-level lambda atomic system with doppler broadening},
	issn = {2815-5947, 0868-3166},
	url = {https://vjs.ac.vn/index.php/cip/article/view/18214},
	doi = {10.15625/0868-3166/18214},
	abstract = {In this paper, we study the formation of two electromagnetically induced transparency (EIT) windows in a four-level lambda atomic system with Doppler broadening. The depth and the width of the EIT windows are easily changed by adjusting the intensity of the controlling laser ﬁelds. Meanwhile, the position of the EIT windows is also easily shifted by changing the frequency of the laser ﬁelds. In particular, by turning on or off one of the two coupling laser ﬁelds, the probe ﬁeld response can be switched between one or two EIT window regimes, i.e., it is possible to switch between absorption and transparency regimes, and vice versa. In addition, our analytical model also allows one to investigate the inﬂuence of temperature (or Doppler width) on EIT windows, which is necessary for experimental observations as well as related applications at room temperature.},
	language = {en},
	urldate = {2026-03-20},
	journal = {Communications in Physics},
	author = {Nguyen Thi Thu, Hien and Nguyen Huy, Bang and Le Van, Doai and Hoang Minh, Dong},
	month = dec,
	year = {2023},
	file = {PDF:files/129/Nguyen Thi Thu et al. - 2023 - Double electromagnetically induced transparency in a four-level lambda atomic system with doppler br.pdf:application/pdf},
}

@article{bharti_study_2015,
	title = {Study of a four-level system in vee + ladder configuration},
	volume = {356},
	issn = {00304018},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0030401815300341},
	doi = {10.1016/j.optcom.2015.08.042},
	abstract = {We present the results of a theoretical study of a four-level atomic system in vee þ ladder conﬁguration using a density matrix analysis. The absorption and dispersion proﬁles are derived for a weak probe ﬁeld and for varying strengths of the two strong control ﬁelds. For speciﬁcity, we choose energy levels of 87Rb, and present results for both stationary atoms and moving atoms in room temperature vapor. An electromagnetically induced absorption (EIA) peak with negative dispersion is observed at zero probe detuning when the control ﬁelds have equal strengths, which switches to electromagnetically induced transparency (EIT) with positive dispersion (due to splitting of the EIA peak) when the control ﬁelds are unequal. There is signiﬁcant linewidth narrowing in thermal vapor.},
	language = {en},
	urldate = {2026-03-20},
	journal = {Optics Communications},
	author = {Bharti, Vineet and Natarajan, Vasant},
	month = dec,
	year = {2015},
	pages = {510--514},
	file = {PDF:files/130/Bharti and Natarajan - 2015 - Study of a four-level system in vee + ladder configuration.pdf:application/pdf},
}

