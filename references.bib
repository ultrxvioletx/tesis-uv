	url = {http://arxiv.org/abs/2007.05030},
	doi = {10.1103/PhysRevLett.125.077701},
	abstract = {Spectral properties of a quantum circuit are efficiently read out by monitoring the resonance frequency shift it induces in a microwave resonator coupled to it. When the two systems are strongly detuned, theory attributes the shift to an effective resonator capacitance or inductance that depends on the quantum circuit state. At small detuning, the shift arises from the exchange of virtual photons, as described by the Jaynes-Cummings model. Here we present a theory bridging these two limits and illustrate, with several examples, its necessity for a general description of quantum circuits readout.},
